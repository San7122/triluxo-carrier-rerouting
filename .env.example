# Copy to .env and fill in. The runner loads this automatically.

# --- Closed-source frontier model (OpenAI GPT-4o) — the benchmarked baseline ---
# Key: https://platform.openai.com/api-keys
# Run it with:  python -m eval.runner --models gpt4o
OPENAI_API_KEY=sk-proj-...
# Optional override; defaults to gpt-4o
OPENAI_MODEL=gpt-4o

# --- Alternative closed-source model (Claude / Anthropic) ---
# The `claude` preset runs the identical harness if you prefer Claude.
ANTHROPIC_API_KEY=sk-ant-...
# Optional override; defaults to claude-sonnet-5
CLAUDE_MODEL=claude-sonnet-5

# --- Open-source model (Llama 3.1/3.3 or Qwen2.5 via Groq) ---
# Free key: https://console.groq.com/keys
GROQ_API_KEY=gsk_...
# Optional override; defaults to llama-3.3-70b-versatile
# Other options: llama-3.1-8b-instant, qwen-2.5-32b
GROQ_MODEL=llama-3.3-70b-versatile

# --- Open-source model run LOCALLY via LM Studio (no API key needed) ---
# In LM Studio: load a tool-calling capable model, then Developer -> Start Server.
# Run it with:  python -m eval.runner --models lmstudio
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
# Set this to the model id shown in LM Studio (the loaded model), e.g.:
# LMSTUDIO_MODEL=qwen2.5-7b-instruct
